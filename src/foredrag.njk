---
layout: base.njk
eleventyComputed:
  title: "{{ pages.foredrag.title }}"
  description: "{{ pages.foredrag.description }}"
  ogTitle: "{{ pages.foredrag.ogTitle }}"
  ogDescription: "{{ pages.foredrag.ogDescription }}"
canonical: "https://emilsalzer.dk/foredrag/"
ogUrl: "https://emilsalzer.dk/foredrag/"
ogImage: "https://emilsalzer.dk/assets/images/foredrag-1.jpg"
extraHead: |
  <style>
      /* === SPLITSCREEN HERO === */
      .split-hero {
          display: grid;
          grid-template-columns: 1fr 1fr;
      }
      .split-hero-text {
          display: flex;
          flex-direction: column;
          justify-content: center;
          padding: 80px 64px 80px 48px;
          max-width: 640px;
          margin-left: auto;
      }
      .split-hero-text h1 {
          font-size: clamp(42px, 5vw, 64px);
          font-weight: 700;
          line-height: 1.08;
          margin-bottom: 40px;
      }
      .split-hero-text p {
          font-size: 16px;
          line-height: 1.8;
          margin-bottom: 20px;
      }
      .split-hero-text .bt-quote {
          font-style: italic;
          margin: 8px 0 20px;
          padding-left: 20px;
          border-left: 2px solid var(--black);
      }
      .split-hero-image {
          position: relative;
      }
      .split-hero-image img {
          width: 100%;
          height: auto;
          object-fit: contain;
      }

      /* === FULL-WIDTH IMAGES === */
      .full-image {
          width: 100%;
          line-height: 0;
      }
      .full-image img {
          width: 100%;
          height: auto;
          display: block;
      }

      /* === HERO IMAGE (fixed height, focus on subject) === */
      .full-image.hero-image {
          overflow: visible;
      }
      .full-image.hero-image img {
          width: 100%;
          height: auto;
          object-fit: contain;
      }

      /* === BOOKING SECTION — full-width, centered content, box-shadow === */
      .booking-section {
          width: 100%;
          margin: 0;
          padding: 80px 48px;
          background: var(--white);
          box-shadow: 0 8px 40px rgba(0, 0, 0, 0.10), 0 -4px 20px rgba(0, 0, 0, 0.04);
      }
      .booking-inner {
          max-width: 560px;
          margin: 0 auto;
      }
      .booking-section h2 {
          font-size: clamp(28px, 3.5vw, 36px);
          font-weight: 700;
          margin-bottom: 32px;
          line-height: 1.2;
      }
      .form-group { margin-bottom: 24px; }
      .form-group label {
          display: block;
          font-style: italic;
          font-size: 15px;
          color: var(--grey);
          margin-bottom: 6px;
      }
      .form-group input,
      .form-group textarea {
          width: 100%;
          border: none;
          border-bottom: 1px solid var(--black);
          padding: 8px 0;
          font-family: 'Times New Roman', Times, serif;
          font-size: 16px;
          background: transparent;
          color: var(--black);
          outline: none;
          transition: border-color 0.2s;
      }
      .form-group input:focus,
      .form-group textarea:focus {
          border-bottom-color: var(--grey);
      }
      .form-group textarea {
          resize: vertical;
          min-height: 80px;
      }
      .form-row {
          display: grid;
          grid-template-columns: 1fr 1fr;
          gap: 24px;
      }
      .form-submit {
          display: inline-block;
          padding: 14px 48px;
          background: var(--black);
          color: var(--white);
          border: none;
          font-family: 'Times New Roman', Times, serif;
          font-size: 15px;
          font-weight: 700;
          letter-spacing: 0.5px;
          cursor: pointer;
          transition: opacity 0.2s;
          margin-top: 8px;
      }
      .form-submit:hover { opacity: 0.8; }
      .success-message {
          display: none;
          padding: 20px;
          background: var(--light-grey);
          text-align: center;
          font-size: 16px;
          margin-top: 20px;
      }

      /* === CREDENTIAL BOXES === */
      .credentials {
          display: grid;
          grid-template-columns: 1fr 1fr 1fr;
      }
      .credential-box {
          padding: 48px 40px;
          background: var(--white);
      }
      .credential-box.grey-bg {
          background: var(--light-grey);
      }
      .credential-box .quote-marks {
          font-size: 48px;
          line-height: 1;
          color: var(--grey);
          margin-bottom: 12px;
          font-style: normal;
      }
      .credential-box blockquote {
          font-style: italic;
          font-size: 16px;
          line-height: 1.8;
          color: var(--black);
          margin-bottom: 16px;
      }
      .credential-box .attribution {
          font-size: 14px;
          font-weight: 700;
          color: var(--black);
      }

      /* === RESPONSIVE === */
      @media (max-width: 900px) {
          .split-hero {
              grid-template-columns: 1fr;
              min-height: auto;
          }
          .split-hero-text {
              padding: 40px 24px;
              max-width: 100%;
              order: 1;
          }
          .split-hero-image {
              order: 2;
          }
          .booking-section { padding: 40px 24px; }
          .form-row { grid-template-columns: 1fr; }
          .full-image.hero-image { height: auto; overflow: visible; }
          .full-image.hero-image img { height: auto; object-fit: contain; width: 100%; }
          .credentials { grid-template-columns: 1fr; }
          .credential-box { padding: 40px 24px; }
      }
  </style>
extraScripts: |
  <script>
  if (window.location.hash === '#tak') {
      document.getElementById('bookingForm').style.display = 'none';
      document.getElementById('successMsg').style.display = 'block';
  }
  </script>
---

<!-- 1. SPLITSCREEN HERO: Tekst venstre, billede højre -->
<section class="split-hero">
    <div class="split-hero-text" data-reveal>
        <h1>{{ pages.foredrag.heading | replace("\n", "<br>") | safe }}</h1>

        <p>{{ pages.foredrag.intro1 }}</p>

        <p class="bt-quote">{{ pages.foredrag.btQuote }}</p>

        <p>{{ pages.foredrag.intro2 }}</p>

        <p>{{ pages.foredrag.intro3 }}</p>
    </div>
    <div class="split-hero-image">
        <img src="/assets/images/foredrag-1.jpg" alt="Emil Salzer holder foredrag for publikum">
    </div>
</section>

<!-- 2. BOOKING FORM — kant-til-kant, centreret indhold, box-shadow -->
<div class="booking-section" data-reveal>
    <div class="booking-inner">
        <h2>{{ pages.foredrag.bookingHeading }}</h2>

        <form action="https://formspree.io/f/{{ pages.foredrag.formspreeId }}" method="POST" id="bookingForm">
            <input type="hidden" name="_subject" value="Booking af foredrag via emilsalzer.dk">
            <input type="hidden" name="_next" value="https://emilsalzer.dk/foredrag/#tak">

            <div class="form-group">
                <label for="name">Navn</label>
                <input type="text" id="name" name="name" required>
            </div>

            <div class="form-group">
                <label for="org">Organisation</label>
                <input type="text" id="org" name="organisation">
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label for="email">E-mail</label>
                    <input type="email" id="email" name="email" required>
                </div>
                <div class="form-group">
                    <label for="phone">Telefon</label>
                    <input type="tel" id="phone" name="telefon">
                </div>
            </div>

            <div class="form-group">
                <label for="message">Evt. kommentar</label>
                <textarea id="message" name="message" rows="3"></textarea>
            </div>

            <button type="submit" class="form-submit">Send</button>
        </form>

        <div class="success-message" id="successMsg">
            {{ pages.foredrag.successMessage }}
        </div>
    </div>
</div>

<!-- 3. FULL-WIDTH: CEPOS konference -->
<div class="full-image">
    <img src="/assets/images/cepos.jpg" alt="Emil Salzer taler ved CEPOS' ytringsfrihedskonference" loading="lazy">
</div>

<!-- 4. CREDENTIAL BOXES -->
<section class="credentials" data-reveal>
    {% for review in pages.foredrag.reviews %}
    <div class="credential-box{% if loop.index == 2 %} grey-bg{% endif %}">
        <div class="quote-marks">&ldquo;</div>
        <blockquote>{{ review.quote }}</blockquote>
        <p class="attribution">{{ review.attribution }}</p>
    </div>
    {% endfor %}
</section>

<!-- 5. FULL-WIDTH: Emil læser op — focus på Emil -->
<div class="full-image hero-image">
    <img src="/assets/images/foredrag-3.jpg" alt="Emil Salzer læser op fra sin bog" loading="lazy">
</div>
