---
layout: base.njk
eleventyComputed:
  title: "{{ pages.forside.title }}"
  description: "{{ pages.forside.description }}"
  ogTitle: "{{ pages.forside.ogTitle }}"
  ogDescription: "{{ pages.forside.ogDescription }}"
canonical: "https://emilsalzer.dk/"
ogUrl: "https://emilsalzer.dk/"
ogImage: "https://emilsalzer.dk/assets/images/forside-1.jpg"
extraHead: |
  <style>
  /* === HERO === */
  .hero {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 85vh;
    overflow: hidden;
  }
  .hero-text {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 80px 64px;
  }
  .hero-tagline {
    font-size: 15px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--grey);
    margin-bottom: 20px;
  }
  .hero-title {
    font-size: clamp(56px, 7vw, 96px);
    font-weight: 700;
    line-height: 1.0;
    margin-bottom: 40px;
  }
  .hero-quote {
    font-style: italic;
    font-size: 17px;
    line-height: 1.7;
    color: var(--black);
    margin-bottom: 12px;
    max-width: 480px;
  }
  .hero-quote-source {
    font-size: 14px;
    color: var(--grey);
    margin-bottom: 40px;
  }
  .hero-buttons {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
  }
  .btn-primary {
    display: inline-block;
    padding: 14px 40px;
    background: var(--black);
    color: var(--white);
    text-decoration: none;
    font-family: 'Times New Roman', Times, Georgia, serif;
    font-size: 15px;
    letter-spacing: 0.5px;
    transition: opacity 0.2s;
  }
  .btn-primary:hover { opacity: 0.8; }
  .btn-secondary {
    display: inline-block;
    padding: 14px 40px;
    background: transparent;
    color: var(--black);
    text-decoration: none;
    font-family: 'Times New Roman', Times, Georgia, serif;
    font-size: 15px;
    letter-spacing: 0.5px;
    border: 1px solid var(--black);
    transition: opacity 0.2s;
  }
  .btn-secondary:hover { opacity: 0.6; }
  .hero-image {
    position: relative;
    overflow: hidden;
  }
  .hero-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
  }

  /* === BANNER === */
  .banner {
    background: var(--black);
    padding: 60px 48px;
    text-align: center;
  }
  .banner p {
    font-size: clamp(22px, 3vw, 32px);
    font-weight: 700;
    color: var(--white);
    line-height: 1.5;
    max-width: 720px;
    margin: 0 auto;
  }

  /* === FULLSCREEN IMAGE === */
  .fullscreen-image {
    position: relative;
    width: 100%;
    height: 80vh;
    overflow: hidden;
  }
  .fullscreen-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .fullscreen-image.uncropped {
    height: auto;
    overflow: visible;
  }
  .fullscreen-image.uncropped img {
    height: auto;
    object-fit: contain;
  }
  .fullscreen-image.crop-bottom img {
    object-position: center 40%;
  }

  /* === FULL-WIDTH HERO IMAGE (bottom image) === */
  .full-image {
    width: 100%;
    line-height: 0;
  }
  .full-image img {
    width: 100%;
    height: auto;
    display: block;
  }
  .full-image.hero-image {
    height: 70vh;
    overflow: hidden;
  }
  .full-image.hero-image img {
    height: 100%;
    object-fit: cover;
    object-position: center 20%;
  }

  /* === SPLIT SECTIONS === */
  .split-sections {
    display: grid;
    grid-template-columns: 1fr 1fr;
  }
  .split-box {
    padding: 80px 64px;
  }
  .split-box.white-bg { background: var(--white); }
  .split-box.grey-bg { background: var(--light-grey); }
  .split-box h2 {
    font-size: clamp(28px, 3.5vw, 40px);
    font-weight: 700;
    margin-bottom: 28px;
    line-height: 1.2;
  }
  .split-box p {
    font-size: 16px;
    line-height: 1.8;
    margin-bottom: 20px;
    color: var(--black);
  }
  .split-box .quote {
    font-style: italic;
    font-size: 16px;
    line-height: 1.8;
    color: var(--black);
    margin: 24px 0;
  }
  .split-box .quote-source {
    font-size: 14px;
    color: var(--grey);
    font-style: italic;
  }
  .split-box .btn-primary,
  .split-box .btn-secondary {
    margin-top: 16px;
  }

  /* === RESPONSIVE === */
  @media (max-width: 900px) {
    .hero { grid-template-columns: 1fr; min-height: auto; }
    .hero-text { padding: 48px 24px; order: 1; }
    .hero-image { order: 2; height: 50vh; }
    .banner { padding: 48px 24px; }
    .fullscreen-image { height: 50vh; }
    .fullscreen-image.uncropped { height: auto; }
    .full-image.hero-image { height: auto; overflow: visible; }
    .full-image.hero-image img { height: auto; object-fit: contain; width: 100%; }
    .split-sections { grid-template-columns: 1fr; }
    .split-box { padding: 48px 24px; }
  }

  @media (max-width: 560px) {
    .hero-title { font-size: 48px; }
    .hero-buttons { flex-direction: column; }
    .hero-buttons a { text-align: center; }
  }

  /* View Transitions */
  @view-transition { navigation: auto; }
  ::view-transition-old(root),
  ::view-transition-new(root) {
    animation-duration: 0.3s;
  }
  </style>
---

<!-- HERO -->
<section class="hero">
  <div class="hero-text" data-reveal>
    <p class="hero-tagline">{{ pages.forside.heroTagline }}</p>
    <h1 class="hero-title">Emil<br>Salzer.</h1>
    <p class="hero-quote">{{ pages.forside.heroQuote }}</p>
    <p class="hero-quote-source">{{ pages.forside.heroQuoteSource }}</p>
    <div class="hero-buttons">
      <a href="/boeger/" class="btn-primary" style="font-weight:700;">Se b&oslash;ger</a>
      <a href="/foredrag/" class="btn-secondary">Book foredrag</a>
    </div>
  </div>
  <div class="hero-image">
    <img src="/assets/images/forside-1.jpg" alt="Emil Salzer, portr&aelig;t" loading="eager">
  </div>
</section>

<!-- BERLINGSKE BANNER -->
<div class="banner" data-reveal>
  <p>{{ pages.forside.bannerText }}</p>
</div>

<!-- FULLSCREEN IMAGE -->
<div class="fullscreen-image uncropped">
  <img src="/assets/images/forside-2.jpg" alt="Emil Salzer, n&aelig;rbillede" loading="lazy">
</div>

<!-- SPLIT SECTIONS -->
<div class="split-sections">
  <div class="split-box white-bg" data-reveal>
    <h2>{{ pages.forside.section1h2 }}</h2>
    <p>{{ pages.forside.section1body }}</p>
    <p class="quote">{{ pages.forside.section1quote }}</p>
    <p class="quote-source">{{ pages.forside.section1quoteSource }}</p>
    <p>{{ pages.forside.section1cta }}</p>
    <a href="/poesi/" class="btn-primary" style="font-weight:700;">L&aelig;s poesi</a>
  </div>
  <div class="split-box grey-bg" data-reveal>
    <h2>{{ pages.forside.section2h2 }}</h2>
    <p>{{ pages.forside.section2intro }}</p>
    <p class="quote">{{ pages.forside.section2quote }}</p>
    <p>{{ pages.forside.section2body }}</p>
    <a href="/filosofi/" class="btn-secondary" style="font-weight:bold;">Filosofi</a>
  </div>
</div>

<!-- FULLSCREEN POLITISK HYKLERI -->
<div class="full-image hero-image" style="position:relative;">
  <img src="/assets/images/forside-3.jpg" alt="Graffiti under bro — Politisk Hykleri" loading="lazy">
  <div style="position:absolute;top:0;left:0;right:0;bottom:0;display:flex;align-items:center;justify-content:center;z-index:1;">
    <p style="font-family:'Times New Roman',serif;font-size:clamp(1.5rem,3vw,2.5rem);color:#fff;text-align:center;max-width:600px;padding:0 2rem;font-weight:bold;text-shadow:0 2px 8px rgba(0,0,0,0.6);line-height:1.6;">{{ pages.forside.poem | replace("\n", "<br>") | safe }}</p>
  </div>
</div>
