---
layout: base.njk
eleventyComputed:
  title: "{{ pages.poesi.title }}"
  description: "{{ pages.poesi.description }}"
  ogTitle: "{{ pages.poesi.ogTitle }}"
  ogDescription: "{{ pages.poesi.ogDescription }}"
canonical: "https://emilsalzer.dk/poesi/"
ogUrl: "https://emilsalzer.dk/poesi/"
ogImage: "https://emilsalzer.dk/assets/images/forside-3.jpg"
extraHead: |
  <style>
      .page-hero { text-align: center; padding: 48px 48px 32px; }
      .page-hero h1 { font-size: clamp(48px, 6vw, 72px); font-weight: 700; line-height: 1.1; }

      .intro {
          max-width: 640px;
          margin: 0 auto;
          padding: 0 48px 60px;
          text-align: left;
          font-size: 16px;
          line-height: 1.8;
          color: var(--black);
      }

      .poem-section {
          max-width: 640px;
          margin: 0 auto;
          padding: 0 48px 80px;
      }
      .poem-year {
          font-size: 18px;
          font-weight: 700;
          margin-bottom: 4px;
      }
      .poem-year-line {
          width: 200px;
          height: 2px;
          background: var(--black);
          margin-bottom: 32px;
      }
      .poem-title {
          font-size: clamp(28px, 4vw, 40px);
          font-weight: 700;
          margin-bottom: 32px;
          line-height: 1.15;
      }
      .poem-body {
          font-size: 16px;
          line-height: 1.9;
      }
      .poem-body .stanza {
          margin-bottom: 28px;
      }
      .poem-body em {
          font-style: italic;
      }
      .poem-note {
          font-style: italic;
          color: var(--black);
          margin-top: 40px;
          font-size: 14px;
      }
      .poem-note a {
          color: var(--black);
      }

      .poem-divider {
          width: 60px;
          height: 1px;
          background: var(--border);
          margin: 80px auto;
      }

      @media (max-width: 900px) {
          .page-hero { padding: 32px 24px 24px; }
          .intro { padding: 0 24px 40px; }
          .poem-section { padding: 0 24px 60px; }
      }
  </style>
---

<section class="page-hero" data-reveal>
    <h1>{{ pages.poesi.heading }}</h1>
</section>

<div class="intro" data-reveal>
    <p>{{ pages.poesi.intro }}</p>
    <p>{{ pages.poesi.introCta }}</p>
</div>

{% for poem in collections.poesi | reverse %}
<div class="poem-section" data-reveal>
    <div class="poem-year">{{ poem.data.year }}</div>
    <div class="poem-year-line"></div>
    <h2 class="poem-title">{{ poem.data.title }}</h2>
    <div class="poem-body">
        {{ poem.templateContent | safe }}
    </div>
    {% if poem.data.note %}
    <p class="poem-note">{{ poem.data.note }}</p>
    {% endif %}
</div>
{% if not loop.last %}
<div class="poem-divider"></div>
{% endif %}
{% endfor %}
