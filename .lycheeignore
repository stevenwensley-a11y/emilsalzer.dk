# Lychee ignore list — emilsalzer.dk
# Format: one pattern per line (regex or exact URL)

# Localhost / dev URLs
http://localhost
https://localhost
http://127.0.0.1

# Formspree endpoints (POST-only, GET returns 405)
https://formspree.io

# Fonts and external CDNs (rate-limited, flaky in CI)
https://fonts.googleapis.com
https://fonts.gstatic.com

# Supabase (requires auth)
https://*.supabase.co

# GitHub Actions badges (often rate-limited)
https://github.com/Bygmedai/.*/actions/workflows/.*\.svg

# Social media (aggressive bot detection)
https://www.linkedin.com
https://twitter.com
https://x.com
https://www.instagram.com
https://www.facebook.com

# Calendly (requires auth)
https://calendly.com

# Old repo URL (transferred — GitHub redirects but lychee may not follow)
https://github.com/stevenwensley-a11y

# GitHub status page (HTTP varies by region)
https://githubstatus.com

# File hosting (requires cookies/auth for some files)
https://www.mediafire.com

# Google services (require auth)
https://analytics.google.com

# CDN scripts (checked at runtime, not link-check time)
https://unpkg.com

# OAuth worker (internal — requires auth)
https://oauth.bygmedai.dk

# YouTube embeds (often blocked in CI environments)
https://www.youtube.com
https://youtube.com

# Nunjucks template URLs ({{ variable }} — not real URLs)
\{\{
